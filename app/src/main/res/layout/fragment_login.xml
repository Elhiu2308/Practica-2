<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco"
    tools:context=".LoginFragment">

    <ImageView
        android:id="@+id/imgEncabezado"
        style="@style/Imagen.Encabezado"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/imgCopa"
        style="@style/Imagen.Copa"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitulo"
        style="@style/Texto.Titulo.Dorado"
        app:layout_constraintBottom_toTopOf="@id/tarjetaInicio"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgCopa" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tarjetaInicio"
        style="@style/CardView.Login"
        app:layout_constraintBottom_toTopOf="@id/imgCampo"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        tools:ignore="MissingConstraints">

        <LinearLayout
            android:id="@+id/lyContenidoTarjeta"
            style="@style/LayoutLogin">

            <TextView
                android:id="@+id/tvTituloSesion"
                style="@style/Texto.Titulo.Tarjeta" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCorreoElectronico"
                style="@style/TextInputLayout.Login.Correo">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreoElectronico"
                    style="@style/TextInputEditText.Login.Correo" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilContrasena"
                style="@style/TextInputLayout.Login.Contrasena">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContrasena"
                    style="@style/TextInputEditText.Login.Contrasena" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvOlvidoContrasena"
                style="@style/Texto.Azul.Restablecer" />

            <Button
                android:id="@+id/btnIngresar"
                style="@style/Boton.Inicio" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/imgCampo"
        style="@style/Imagen.Campo"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="MissingConstraints" />

    <View
        android:id="@+id/vistaGradiente"
        style="@style/Gradiente"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTextoPie"
        style="@style/Texto.Pie"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <Button
        android:id="@+id/btnCambiarIdioma"
        style="@style/Boton.Idioma"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>